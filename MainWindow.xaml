<Window x:Class="ThirdTaskApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThirdTaskApplication"
        mc:Ignorable="d"
        Title="RSA Application"
        Height="600"
        Width="850"
        MinHeight="560"
        MinWidth="800"
        Background="#FFF8DC">

    <Window.Resources>
        <Style x:Key="BaseTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="BaseTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#C8B88A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFFFF4"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E2D39C"
                BorderThickness="1"
                Margin="0,0,15,0">
            <StackPanel DataContext="{Binding CurrentRSA}">
                <TextBlock Text="Параметры RSA"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#4A3B16"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Q:" Style="{StaticResource BaseTextBlock}"/>
                <TextBox x:Name="QTextBox"
                         Style="{StaticResource BaseTextBox}"
                         Text="{Binding Q, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="P:" Style="{StaticResource BaseTextBlock}"/>
                <TextBox x:Name="PTextBox"
                         Style="{StaticResource BaseTextBox}"
                         Text="{Binding P, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="Exponent:" Style="{StaticResource BaseTextBlock}"/>
                <TextBox x:Name="BTextBox"
                         Style="{StaticResource BaseTextBox}"
                         Text="{Binding Exponent, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="Message:" Style="{StaticResource BaseTextBlock}"/>
                <TextBox x:Name="MessageTextBox"
                         Style="{StaticResource BaseTextBox}"
                         Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                         Height="105"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"/>

                <TextBlock Text="Encrypted:" Style="{StaticResource BaseTextBlock}"/>
                <TextBox x:Name="EncryptedTextBox"
                         Style="{StaticResource BaseTextBox}"
                         IsReadOnly="True"
                         Text="{Binding EncryptedData, UpdateSourceTrigger=PropertyChanged}"
                         Background="#EFEFEF"
                         Height="105"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#FFFFF4"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E2D39C"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Управление"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#4A3B16"
                           Margin="0,0,0,12"/>

                <UniformGrid Grid.Row="1"
                             Columns="2"
                             Margin="0,0,0,10">
                    <Button x:Name="SelectInputFileButton"
                            Command="{Binding SelectInputFileCommand}"
                            Content="Выбрать файл"
                            Background="#337AB7"
                            Style="{StaticResource MainButton}"/>

                    <Button x:Name="SelectOutputFileButton"
                            Command="{Binding SelectOutputFileCommand}"
                            Content="Куда сохранить"
                            Background="#5BC0DE"
                            Style="{StaticResource MainButton}"/>
                </UniformGrid>

                <UniformGrid Grid.Row="2"
                             Columns="2"
                             Margin="0,0,0,10">
                    <Button x:Name="EncryptButton"
                            Command="{Binding EncryptionCommands}"
                            Content="Encrypt"
                            Background="#5CB85C"
                            Style="{StaticResource MainButton}"/>

                    <Button x:Name="DecryptButton"
                            Command="{Binding DecryptedMessage}"
                            Content="Decrypt"
                            Background="#F0AD4E"
                            Style="{StaticResource MainButton}"/>
                </UniformGrid>

                <UniformGrid Grid.Row="3"
                             Columns="2"
                             Margin="0,0,0,18">
                    <Button Grid.Column="1"
                            Command="{Binding EncryptionFromFile}"
                            x:Name="Button1"
                            Content="Зашифровать файл"
                            Background="#6F42C1"
                            Style="{StaticResource MainButton}"/>

                    <Button Grid.Column="1"
                            Command="{Binding DecryptionFromFile}"
                            x:Name="Button2"
                            Content="Расшифровать файл"
                            Background="#D9534F"
                            Style="{StaticResource MainButton}"/>
                </UniformGrid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Decrypted:"
                               Style="{StaticResource BaseTextBlock}"
                               Margin="0,0,0,6"/>

                    <TextBox Grid.Row="1"
                             x:Name="DecryptedTextBox"
                             Text="{Binding CurrentRSA.DecryptedMessage, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Style="{StaticResource BaseTextBox}"
                             Background="#EFEFEF"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>